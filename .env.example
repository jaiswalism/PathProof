# Pinata IPFS Configuration
# Get these from https://app.pinata.cloud/developers/api-keys
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_API_SECRET=your_pinata_api_secret_here
VITE_PINATA_JWT_TOKEN=your_pinata_jwt_token_here

# Blockchain Configuration
# For local development with Anvil
BLOCKCHAIN_RPC_URL=http://localhost:8545

# Copy this from your Anvil CLI output
PRIVATE_KEY=0xacf39Fd6e51aad88F6F4ce6aB8827279cffFb92266rd5efcae784d7bf4f2ff80

# Contract Addresses
# Replace these with your deployed contract addresses
CONTRACT_ADDRESS=your_contract_address_here
VITE_CONTRACT_ADDRESS=your_contract_address_here
VITE_VERIFIER_ADDRESS=your_verifier_contract_address_here

# RPC Configuration
# For testnet deployment (Sepolia example)
# Get your API key from https://infura.io/
VITE_RPC_URL=https://sepolia.infura.io/v3/your_infura_api_key_here

# Device Configuration
VITE_DEVICE_ID=111

# API Configuration
REACT_APP_API_URL=http://localhost:5000

# Admin Configuration
# Your main wallet address (typically the first account from Anvil)
ADMIN_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266